-- 防甩飞
local AntiFallSection = UniversalTab:Section({
    Title = "防甩飞/动作脚本",
    Icon = "shield",
})

AntiFallSection:Button({
    Title = "防甩飞1",
    Callback = function()
        local Char = Me.Character or Me.CharacterAdded:Wait()
        local Root = Char:FindFirstChildOfClass("HumanoidRootPart")
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        local MAX_SPEED = 50
        local MAX_ANGULAR = 50
        
        local function onCharacterAdded(c)
            Char = c
            Root = Char:FindFirstChildOfClass("HumanoidRootPart")
            Hum = Char:FindFirstChildOfClass("Humanoid")
        end
        
        Me.CharacterAdded:Connect(onCharacterAdded)
        
        RunService.PreSimulation:Connect(function()
            if not (Root and Hum and Hum.Health > 0) then return end
            local vel = Root.AssemblyLinearVelocity
            local ang = Root.AssemblyAngularVelocity
            if vel.Magnitude > MAX_SPEED or ang.Magnitude > MAX_ANGULAR then
                Root.AssemblyLinearVelocity = Vector3.new(0, Root.AssemblyLinearVelocity.Y, 0)
                Root.AssemblyAngularVelocity = Vector3.new(0,0,0)
            end
        end)
        WindUI:Notify({ Title = "功能加载", Content = "防甩飞1 已启动", Duration = 2 })
    end
})

AntiFallSection:Button({
    Title = "防甩飞2",
    Callback = function()
        local CollisionGroup = "NoPlayerCollide"
        PhysicsService:RegisterCollisionGroup(CollisionGroup)
        PhysicsService:CollisionGroupSetCollidable(CollisionGroup, CollisionGroup, false)
        
        local function SetGroup(part)
            if part:IsA("BasePart") then
                part.CollisionGroup = CollisionGroup
            end
        end
        
        local function OnCharAdded(c)
            for _,desc in ipairs(c:GetDescendants()) do
                SetGroup(desc)
            end
        end
        
        Me.CharacterAdded:Connect(OnCharAdded)
        if Me.Character then
            task.spawn(OnCharAdded, Me.Character)
        end
        WindUI:Notify({ Title = "功能加载", Content = "防甩飞2 已启动", Duration = 2 })
    end
})

AntiFallSection:Button({
    Title = "飞踢脚本",
