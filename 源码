-- 移动速度
local SpeedSection = UniversalTab:Section({
    Title = "移动速度修改",
    Icon = "gauge",
})

local speedSlider
speedSlider = SpeedSection:Slider({
    Title = "移速滑块",
    Min = 0,
    Max = 250,
    Default = 16,
    Callback = function(value)
        local char = Me.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = value
            WindUI:Notify({ Title = "移动速度", Content = "已设置为: " .. value, Duration = 1 })
        end
    end
})

SpeedSection:Input({
    Title = "移速数值",
    Placeholder = "请输入移速倍数(默认16)",
    Callback = function(value)
        local num = tonumber(value)
        if num and Me.Character then
            local char = Me.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChild("Humanoid")
            if hrp and hum then
                hrp.Velocity = hrp.Velocity.Unit * num
                hum.WalkSpeed = num
                WindUI:Notify({ Title = "移动速度", Content = "已设置为: " .. num, Duration = 2 })
            end
        end
    end
})

